# Docker Compose ports
FRONTEND_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=cloudpulse
POSTGRES_USER=cloudpulse
POSTGRES_PASSWORD=cloudpulse

# Redis / background processing
REDIS_QUEUE_NAME=monitor_checks
WORKER_QUEUE_TIMEOUT_SECONDS=5
SCHEDULER_POLL_INTERVAL_SECONDS=10

# Runtime
ENVIRONMENT=docker
VITE_API_BASE_URL=/api
